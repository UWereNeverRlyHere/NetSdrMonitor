# ---- ASP.NET / runtime artifacts (про всяк випадок) ----
**/wwwroot/lib/
*.dbmdl
*.dbproj.schemaview
*.jfm

# ---- SQLite (локальні БД проєкту; тримаємо схему/код, не дампи) ----
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ---- Secrets / local config ----
appsettings.*.local.json
secrets.json
*.local.user
.env
.env.*

# ---- OS noise ----
.DS_Store
.AppleDouble
.LSOverride
