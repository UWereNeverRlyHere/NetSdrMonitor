## ============================================================
##  .gitignore — .NET / WPF solution (Rider, Visual Studio, VS Code, MSBuild, CLI)
##  Покриває: вихід збірки, файли IDE, кеші, тести, публікації, секрети.
## ============================================================

# ---- Результати збірки ----
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Bb]uilds/
[Ll]og/
[Ll]ogs/
artifacts/

