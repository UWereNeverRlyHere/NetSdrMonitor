<Window x:Class="NetSdrMonitor.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:features="clr-namespace:NetSdrMonitor.Desktop.Features"
        Title="NetSdrMonitor" Height="600" Width="900"
        Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <features:AppTray x:Name="Tray" Grid.Row="0" />

        <Border Grid.Row="0" Background="#11151C" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Click="OnToggle" Width="36" Height="36" ToolTip="Старт/стоп імітації"
                        FontFamily="Segoe MDL2 Assets" FontSize="16">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="&#xE768;" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Content" Value="&#xE769;" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Click="OnSettings" Width="36" Height="36" Margin="6,0,0,0" ToolTip="Налаштування"
                        Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <TextBlock Text="{Binding SignalCount, StringFormat='• сигналів: {0}'}" Foreground="#9AA4B2"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Grid.Row=1: тут пізніше буде таблиця сигналів -->
    </Grid>
</Window>