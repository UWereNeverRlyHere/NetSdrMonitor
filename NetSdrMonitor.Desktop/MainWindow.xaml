<Window x:Class="NetSdrMonitor.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:features="clr-namespace:NetSdrMonitor.Desktop.Features"
        xmlns:behaviors="clr-namespace:NetSdrMonitor.Desktop.Behaviors"
        xmlns:ctrl="clr-namespace:NetSdrMonitor.Desktop.Controls"
        xmlns:console="clr-namespace:NetSdrMonitor.Desktop.Features.Console"
        Title="NetSdrMonitor" Height="600" Width="900"
        Background="#FAFAFB" TextElement.Foreground="#1F2430"
        Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- проксі DataContext для заголовків колонок (вони поза візуальним деревом) -->
        <behaviors:BindingProxy x:Key="Proxy" Data="{Binding}" />

        <!-- вирівнювання числових колонок праворуч -->
        <Style x:Key="NumCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- трохи більший і жирніший заголовок колонок -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ConsoleRow" Height="0" />
        </Grid.RowDefinitions>

        <features:AppTray x:Name="Tray" Grid.Row="0" />

        <!-- панель керування -->
        <Border Grid.Row="0" Background="#EEEFF3" BorderBrush="#DADCE2" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Click="OnToggle" Width="36" Height="36" ToolTip="Старт/стоп імітації"
                        FontFamily="Segoe MDL2 Assets" FontSize="16">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="&#xE768;" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Content" Value="&#xE769;" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button DockPanel.Dock="Left" Click="OnSettings" Width="36" Height="36" Margin="6,0,0,0" ToolTip="Налаштування"
                        Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="16,0,0,0" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding SignalCount, StringFormat='• сигналів: {0}'}" Foreground="#6B7280"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </DockPanel>
        </Border>

        <!-- панель фільтрації -->
        <Border Grid.Row="1" Background="#F5F6F8" BorderBrush="#DADCE2" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Пошук:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox DockPanel.Dock="Left" Width="160" VerticalAlignment="Center"
                         Text="{Binding Table.SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock DockPanel.Dock="Left" Text="SNR ≥" VerticalAlignment="Center" Margin="16,0,6,0" />
                <ctrl:NumericSpinner DockPanel.Dock="Left" Width="84" VerticalAlignment="Center"
                                     IntegerOnly="True" Minimum="0" Maximum="40" Step="1" Value="{Binding Table.MinSnrDb}" />

                <TextBlock DockPanel.Dock="Left" Text="Сигналів ≥" VerticalAlignment="Center" Margin="16,0,6,0" />
                <ctrl:NumericSpinner DockPanel.Dock="Left" Width="84" VerticalAlignment="Center"
                                     IntegerOnly="True" Minimum="0" Step="1" Value="{Binding Table.MinSignalCount}" />

                <Button DockPanel.Dock="Right" Content="Очистити журнал" Click="OnClearLog" Padding="10,3" Margin="8,0,0,0" />
                <Button DockPanel.Dock="Right" Content="Скинути фільтр" Click="OnResetFilter" Padding="10,3" />
            </DockPanel>
        </Border>

        <!-- таблиця агрегованих записів -->
        <DataGrid x:Name="SignalsGrid" Grid.Row="2"
                  ItemsSource="{Binding Table.RowsView}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  RowBackground="White" AlternatingRowBackground="#F6F7F9"
                  BorderThickness="0" Background="White" FontSize="14"
                  ColumnHeaderStyle="{StaticResource HeaderStyle}"
                  Loaded="OnGridLoaded" ColumnReordered="OnColumnsChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- ПКМ виділяє рядок під курсором; далі відкривається контекстне меню гріда -->
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnRowRightClick" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Показати сигнали" Click="OnShowSignals" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn behaviors:ColumnLayout.Key="time" Header="Час" Width="120"
                                    Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss.fff}'}" />
                <DataGridTextColumn behaviors:ColumnLayout.Key="freq" Width="130"
                                    Header="{Binding Data.Table.FrequencyColumnTitle, Source={StaticResource Proxy}}"
                                    Binding="{Binding FrequencyMhz, StringFormat='{}{0:F3}'}"
                                    ElementStyle="{StaticResource NumCell}" />
                <DataGridTextColumn behaviors:ColumnLayout.Key="bw" Header="Смуга, кГц" Width="110"
                                    Binding="{Binding BandwidthKhz, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource NumCell}" />
                <DataGridTextColumn behaviors:ColumnLayout.Key="snr" Header="SNR, дБ" Width="90"
                                    Binding="{Binding SnrDb, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource NumCell}" />
                <DataGridTextColumn behaviors:ColumnLayout.Key="count" Header="Сигналів" Width="90"
                                    Binding="{Binding Count}"
                                    ElementStyle="{StaticResource NumCell}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- роздільник між таблицею та консоллю: тягнемо мишею, висота запам'ятовується -->
        <GridSplitter x:Name="ConsoleSplitter" Grid.Row="3" Height="5" Visibility="Collapsed"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" Background="#DADCE2" />

        <!-- нижня консоль логів монітора (видимість — за налаштуванням) -->
        <console:ConsoleView x:Name="ConsoleHost" Grid.Row="4" Visibility="Collapsed"
                             DataContext="{Binding Console}" />
    </Grid>
</Window>
