<ui:FluentWindow x:Class="NetSdrMonitor.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:features="clr-namespace:NetSdrMonitor.Desktop.Features"
                 xmlns:behaviors="clr-namespace:NetSdrMonitor.Desktop.Behaviors"
                 xmlns:windowing="clr-namespace:NetSdrMonitor.Desktop.Features.Windowing"
                 xmlns:ctrl="clr-namespace:NetSdrMonitor.Desktop.Controls"
                 xmlns:console="clr-namespace:NetSdrMonitor.Desktop.Features.Console"
                 Title="NetSdrMonitor"
                 MinWidth="640" MinHeight="400"
                 windowing:WindowFraction.WidthFraction="0.45"
                 windowing:WindowFraction.HeightFraction="0.5"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <!-- проксі DataContext для заголовка колонки частоти (він поза візуальним деревом) -->
        <behaviors:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <DockPanel>
        <!-- власна плашка заголовка: це елемент контенту, тож назва вікна повністю керована (а не системний каптіон) -->
        <ui:TitleBar DockPanel.Dock="Top" Title="NetSdrMonitor"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     MinHeight="25"
                     Height="28"
                     MaxHeight="35">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/Icons/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="140" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ConsoleRow" Height="0" />
            </Grid.RowDefinitions>

            <features:AppTray x:Name="Tray" Grid.Row="0" />

            <!-- панель керування -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left"
                            Click="OnToggle"
                            Width="30" Height="30"
                            Style="{StaticResource AppButton}"
                            Padding="0"
                            ToolTip="Старт/стоп імітації">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE768;" />            <!-- старт -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;" />      <!-- пауза -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button DockPanel.Dock="Left"
                            Click="OnSettings" 
                            Style="{StaticResource AppButton}"
                            Width="30" Height="30" 
                            Margin="6,0,0,0" Padding="0" 
                            ToolTip="Налаштування">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0" />
                    <TextBlock DockPanel.Dock="Left" Text="{Binding SignalCount, StringFormat='• сигналів: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </DockPanel>
            </Border>

            <!-- основна область: ліворуч фіксована панель фільтрів, праворуч таблиця -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ліва панель: лічильник записів + фільтри (фіксована ширина, зі скролом на низькому вікні) -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- закріплено НАД скролом: лічильник + дії (скинути фільтр / очистити журнал) -->
                        <StackPanel DockPanel.Dock="Top" Margin="10,10,10,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <!-- кількість показаних записів (з урахуванням активного фільтра) -->
                                <TextBlock Text="{Binding Table.VisibleCount, StringFormat='Всього записів: {0}'}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                                <!-- вертикальний роздільник між лічильником і діями -->
                                <Border Width="1" Margin="8,2" VerticalAlignment="Stretch"
                                        Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                <Button Click="OnResetFilter"
                                        Style="{StaticResource AppButton}"
                                        Width="28" Height="28" Padding="0" Margin="0,0,8,0"
                                        VerticalAlignment="Center" ToolTip="Скинути фільтр">
                                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                                <Button Click="OnClearLog"
                                        Style="{StaticResource AppButton}"
                                        Width="28" Height="28" Padding="0"
                                        VerticalAlignment="Center" ToolTip="Очистити журнал">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>
                            <Separator Margin="0,0,0,8" />
                        </StackPanel>

                        <!-- прокручувані фільтри (заповнюють решту висоти панелі) -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10,0,10,10">
                            <TextBlock Text="{Binding Table.FrequencyFilterTitle}" Margin="0,0,0,2" />
                            <ctrl:NumericSpinner Height="32" Margin="0,0,0,10"
                                                 Minimum="0" Step="1"
                                                 Value="{Binding Table.MinFrequencyMhz}" />

                            <TextBlock Text="Смуга ≥, кГц" Margin="0,0,0,2" />
                            <ctrl:NumericSpinner Height="32" Margin="0,0,0,10"
                                                 Minimum="0" Step="5"
                                                 Value="{Binding Table.MinBandwidthKhz}" />

                           
                            <TextBlock Text="SNR ≥" Margin="0,0,0,2" />
                            <ctrl:NumericSpinner Height="32" Margin="0,0,0,10"
                                                 IntegerOnly="True" Minimum="0" Maximum="40" Step="1"
                                                 Value="{Binding Table.MinSnrDb}" />

                            <TextBlock Text="Сигналів ≥" Margin="0,0,0,2" />
                            <ctrl:NumericSpinner Height="32" Margin="0,0,0,10"
                                                 IntegerOnly="True" Minimum="0" Step="1"
                                                 Value="{Binding Table.MinSignalCount}" />
                            <TextBlock Text="Час ≥ (год:хв)" Margin="0,0,0,2" />
                            <ctrl:TimePicker Margin="0,0,0,10"
                                             Text="{Binding Table.MinTimeText, Mode=TwoWay}" />

                            <TextBlock Text="Дата з" Margin="0,0,0,2" />
                            <DatePicker Margin="0,0,0,10" SelectedDate="{Binding Table.FromDate, Mode=TwoWay}" />

                            <TextBlock Text="Дата по" Margin="0,0,0,2" />
                            <DatePicker Margin="0,0,0,12" SelectedDate="{Binding Table.ToDate, Mode=TwoWay}" />

                            <Button Content="Сьогодні"
                                    Command="{Binding Table.TodayCommand}"
                                    Style="{StaticResource AppButton}"
                                    HorizontalAlignment="Stretch" Height="32" Margin="0,0,0,8" />

                      
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

            <!-- таблиця агрегованих записів: заголовки, виділення й чергування рядків бере тема WPF-UI -->
            <DataGrid x:Name="SignalsGrid" Grid.Column="1"
                      Style="{StaticResource AppDataGrid}"
                      ItemsSource="{Binding Table.RowsView}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="{DynamicResource ApplicationBackgroundBrush}"
                      BorderThickness="0" FontSize="14"
                      PreviewMouseRightButtonDown="OnRowRightClick"
                      Loaded="OnGridLoaded" ColumnReordered="OnColumnsChanged"
                      Sorting="OnGridSorting"
                      behaviors:RowAppearAnimation.Enabled="True">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Показати сигнали" Click="OnShowSignals" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <!-- Дата й Час — пов'язана пара: сортуються разом, стрілка стоїть на обох -->
                    <DataGridTextColumn behaviors:ColumnLayout.Key="date" Header="Дата"
                                        MinWidth="100" Width="110" MaxWidth="200"
                                        SortMemberPath="Date" SortDirection="Descending"
                                        Binding="{Binding Time, StringFormat='{}{0:dd.MM.yyyy}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="time" Header="Час"
                                        MinWidth="100" Width="110" MaxWidth="200"
                                        SortMemberPath="Time" SortDirection="Descending"
                                        Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="freq"
                                        MinWidth="100" Width="130" MaxWidth="200"
                                        Header="{Binding Data.Table.FrequencyColumnTitle, Source={StaticResource Proxy}}"
                                        Binding="{Binding FrequencyMhz, StringFormat='{}{0:F3}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="bw" Header="Смуга, кГц"
                                        MinWidth="90" Width="110" MaxWidth="170"
                                        Binding="{Binding BandwidthKhz, StringFormat='{}{0:F1}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="snr" Header="SNR, дБ"
                                        MinWidth="60" Width="80" MaxWidth="150"
                                        Binding="{Binding SnrDb, StringFormat='{}{0:F1}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="count" Header="Сигналів"
                                        MinWidth="60" Width="90" MaxWidth="150"
                                        Binding="{Binding Count}"
                                        ElementStyle="{StaticResource CellCenter}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- індикатор зайнятості: накриває таблицю під час перезавантаження набору з БД -->
            <Border Grid.Column="1" Background="#33000000"
                    Visibility="{Binding Table.IsLoading, Converter={StaticResource BoolToVis}}">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            </Grid>

            <!-- роздільник між таблицею та консоллю: тягнемо мишею, висота запам'ятовується -->
            <GridSplitter x:Name="ConsoleSplitter" Grid.Row="2" Height="5" Visibility="Collapsed"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- нижня консоль логів монітора (видимість — за налаштуванням) -->
            <console:ConsoleView x:Name="ConsoleHost" Grid.Row="3" Visibility="Collapsed"
                                 DataContext="{Binding Console}" />
        </Grid>
    </DockPanel>
</ui:FluentWindow>