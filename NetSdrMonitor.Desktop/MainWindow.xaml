<ui:FluentWindow x:Class="NetSdrMonitor.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:features="clr-namespace:NetSdrMonitor.Desktop.Features"
                 xmlns:behaviors="clr-namespace:NetSdrMonitor.Desktop.Behaviors"
                 xmlns:ctrl="clr-namespace:NetSdrMonitor.Desktop.Controls"
                 xmlns:console="clr-namespace:NetSdrMonitor.Desktop.Features.Console"
                 Title="NetSdrMonitor"
                 MinWidth="640" MinHeight="400"
                 behaviors:WindowFraction.WidthFraction="0.45"
                 behaviors:WindowFraction.HeightFraction="0.5"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <!-- проксі DataContext для заголовка колонки частоти (він поза візуальним деревом) -->
        <behaviors:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </ui:FluentWindow.Resources>

    <DockPanel>
        <!-- власна плашка заголовка: це елемент контенту, тож назва вікна повністю керована (а не системний каптіон) -->
        <ui:TitleBar DockPanel.Dock="Top" Title="NetSdrMonitor"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     MinHeight="25"
                     Height="28"
                     MaxHeight="35">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/Icons/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="140" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ConsoleRow" Height="0" />
            </Grid.RowDefinitions>

            <features:AppTray x:Name="Tray" Grid.Row="0" />

            <!-- панель керування -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left"
                            Click="OnToggle"
                            Width="30" Height="30"
                            Style="{StaticResource AppButton}"
                            Padding="0"
                            ToolTip="Старт/стоп імітації">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE768;" />            <!-- старт -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="&#xE769;" />      <!-- пауза -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button DockPanel.Dock="Left"
                            Click="OnSettings" 
                            Style="{StaticResource AppButton}"
                            Width="30" Height="30" 
                            Margin="6,0,0,0" Padding="0" 
                            ToolTip="Налаштування">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                    </Button>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0" />
                    <TextBlock DockPanel.Dock="Left" Text="{Binding SignalCount, StringFormat='• сигналів: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </DockPanel>
            </Border>

            <!-- панель фільтрації -->
            <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Text="Пошук:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox DockPanel.Dock="Left" Width="160" VerticalAlignment="Center"
                             Text="{Binding Table.SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock DockPanel.Dock="Left" Text="SNR ≥" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <ctrl:NumericSpinner DockPanel.Dock="Left" Width="64" Height="32" VerticalAlignment="Center"
                                         IntegerOnly="True" Minimum="0" Maximum="40" Step="1" Value="{Binding Table.MinSnrDb}" />

                    <TextBlock DockPanel.Dock="Left" Text="Сигналів ≥" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <ctrl:NumericSpinner DockPanel.Dock="Left" Width="64" Height="32" VerticalAlignment="Center"
                                         IntegerOnly="True" Minimum="0" Step="1" Value="{Binding Table.MinSignalCount}" />

                    <!-- фільтр за датою: діапазон С/По (календарик) + швидкий «Сьогодні» -->
                    <TextBlock DockPanel.Dock="Left" Text="Дата:" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <DatePicker DockPanel.Dock="Left" Width="120" VerticalAlignment="Center"
                                SelectedDate="{Binding Table.FromDate, Mode=TwoWay}" />
                    <TextBlock DockPanel.Dock="Left" Text="—" VerticalAlignment="Center" Margin="4,0" />
                    <DatePicker DockPanel.Dock="Left" Width="120" VerticalAlignment="Center"
                                SelectedDate="{Binding Table.ToDate, Mode=TwoWay}" />
                    <Button DockPanel.Dock="Left" Content="Сьогодні"
                            Command="{Binding Table.TodayCommand}"
                            Style="{StaticResource AppButton}"
                            Height="32" Padding="10,3" Margin="6,0,0,0" />

                    <Button DockPanel.Dock="Right" Content="Очистити журнал"
                            Click="OnClearLog" 
                            Style="{StaticResource AppButton}"
                            Height="32" Padding="10,3" Margin="8,0,0,0" />
                    <Button DockPanel.Dock="Right" Content="Скинути фільтр"
                            Click="OnResetFilter" 
                            Style="{StaticResource AppButton}"
                            Height="32"  Padding="10,3" />
                </DockPanel>
            </Border>

            <!-- таблиця агрегованих записів: заголовки, виділення й чергування рядків бере тема WPF-UI -->
            <DataGrid x:Name="SignalsGrid" Grid.Row="2"
                      Style="{StaticResource AppDataGrid}"
                      ItemsSource="{Binding Table.RowsView}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="{DynamicResource ApplicationBackgroundBrush}"
                      BorderThickness="0" FontSize="14"
                      PreviewMouseRightButtonDown="OnRowRightClick"
                      Loaded="OnGridLoaded" ColumnReordered="OnColumnsChanged">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Показати сигнали" Click="OnShowSignals" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn behaviors:ColumnLayout.Key="date" Header="Дата" 
                                        MinWidth="100" Width="110" MaxWidth="200"
                                        Binding="{Binding Time, StringFormat='{}{0:dd.MM.yyyy}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <!-- SortDirection лише показує стрілку в заголовку; саме сортування тримає RowsView -->
                    <DataGridTextColumn behaviors:ColumnLayout.Key="time" Header="Час" 
                                        MinWidth="100" Width="110" MaxWidth="200"
                                        SortDirection="Descending"
                                        Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="freq"
                                        MinWidth="100" Width="130" MaxWidth="200"
                                        Header="{Binding Data.Table.FrequencyColumnTitle, Source={StaticResource Proxy}}"
                                        Binding="{Binding FrequencyMhz, StringFormat='{}{0:F3}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="bw" Header="Смуга, кГц"
                                        MinWidth="90" Width="110" MaxWidth="170"
                                        Binding="{Binding BandwidthKhz, StringFormat='{}{0:F1}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="snr" Header="SNR, дБ"
                                        MinWidth="60" Width="80" MaxWidth="150"
                                        Binding="{Binding SnrDb, StringFormat='{}{0:F1}'}"
                                        ElementStyle="{StaticResource CellCenter}" />
                    <DataGridTextColumn behaviors:ColumnLayout.Key="count" Header="Сигналів"
                                        MinWidth="60" Width="90" MaxWidth="150"
                                        Binding="{Binding Count}"
                                        ElementStyle="{StaticResource CellCenter}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- роздільник між таблицею та консоллю: тягнемо мишею, висота запам'ятовується -->
            <GridSplitter x:Name="ConsoleSplitter" Grid.Row="3" Height="5" Visibility="Collapsed"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- нижня консоль логів монітора (видимість — за налаштуванням) -->
            <console:ConsoleView x:Name="ConsoleHost" Grid.Row="4" Visibility="Collapsed"
                                 DataContext="{Binding Console}" />
        </Grid>
    </DockPanel>
</ui:FluentWindow>