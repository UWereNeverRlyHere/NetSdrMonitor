<UserControl x:Class="NetSdrMonitor.Desktop.Features.AppTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <tb:TaskbarIcon x:Name="TrayIcon"
                    IconSource="/Assets/Icons/app.ico"
                    ToolTipText="NetSdrMonitor"
                    TrayLeftMouseUp="OnShowMain">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu Opened="OnMenuOpened">
                <MenuItem x:Name="ToggleItem" Header="Розпочати імітацію" Click="OnToggle"/>
                <Separator/>
                <MenuItem Header="Основне вікно" Click="OnShowMain"/>
                <MenuItem Header="Налаштування"  Click="OnSettings"/>
                <Separator/>
                <MenuItem Header="Вийти" Click="OnExit"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>
</UserControl>