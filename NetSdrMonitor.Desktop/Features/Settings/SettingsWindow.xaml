<Window x:Class="NetSdrMonitor.Desktop.Features.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:ctrl="clr-namespace:NetSdrMonitor.Desktop.Controls"
        Title="Налаштування" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        Icon="/Assets/Icons/app.ico">
   <Window.Resources>
      <!-- тема Fluent поки застосована лише до цього вікна (поетапне впровадження): -->
      <!-- словники тримаємо тут, а не в App.xaml, щоб не чіпати спільний файл -->
      <ResourceDictionary>
         <ResourceDictionary.MergedDictionaries>
            <ui:ThemesDictionary Theme="Light"/>
            <ui:ControlsDictionary/>
         </ResourceDictionary.MergedDictionaries>
      </ResourceDictionary>
   </Window.Resources>
   <StackPanel Margin="16">

      <TextBlock Text="Монітор" FontWeight="Bold" Margin="0,0,0,6"/>
      <Grid>
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
         </Grid.ColumnDefinitions>
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
         </Grid.RowDefinitions>

         <TextBlock Grid.Row="0" Text="Таймаут простою, с" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="0" Grid.Column="1" Margin="0,3" Step="5" Minimum="1" Value="{Binding IdleTimeoutSeconds}"/>

         <TextBlock Grid.Row="1" Text="Пауза реконекту, с" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="1" Grid.Column="1" Margin="0,3" Step="5" Minimum="1" Value="{Binding ReconnectDelaySeconds}"/>

         <TextBlock Grid.Row="2" Text="Таймаут підключення, с" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="2" Grid.Column="1" Margin="0,3" Step="5" Minimum="1" Value="{Binding ConnectTimeoutSeconds}"/>
      </Grid>

      <TextBlock Text="Імітація (мок-сервер)" FontWeight="Bold" Margin="0,14,0,6"/>
      <Grid>
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
         </Grid.ColumnDefinitions>
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
         </Grid.RowDefinitions>

         <TextBlock Grid.Row="0" Text="Інтервал видачі, мс" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="0" Grid.Column="1" Margin="0,3" Step="100" Minimum="10" Value="{Binding SendIntervalMs}"/>

         <TextBlock Grid.Row="1" Text="Ймовірність битого кадру" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="1" Grid.Column="1" Margin="0,3" Step="0.05" Minimum="0" Maximum="1" Value="{Binding MalformedFrameProbability}"/>

         <TextBlock Grid.Row="2" Text="Ймовірність чужого control" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="2" Grid.Column="1" Margin="0,3" Step="0.05" Minimum="0" Maximum="1" Value="{Binding UnknownControlProbability}"/>

         <TextBlock Grid.Row="3" Text="Ймовірність обриву" VerticalAlignment="Center" Margin="0,3"/>
         <ctrl:NumericSpinner Grid.Row="3" Grid.Column="1" Margin="0,3" Step="0.05" Minimum="0" Maximum="1" Value="{Binding DropProbability}"/>
      </Grid>

      <TextBlock Text="Таблиця" FontWeight="Bold" Margin="0,14,0,6"/>
      <CheckBox Content="Показувати медіану частоти (інакше — за першим сигналом)"
                IsChecked="{Binding UseMedianFrequency}"/>

      <TextBlock Text="Консоль" FontWeight="Bold" Margin="0,14,0,6"/>
      <CheckBox Content="Показувати консоль логів (нижня панель)"
                IsChecked="{Binding ShowConsole}"/>

      <TextBlock Text="Сховище" FontWeight="Bold" Margin="0,14,0,6"/>
      <CheckBox Content="Зберігати лише в пам'яті (без файлу БД SQLite)"
                IsChecked="{Binding UseInMemoryStorage}"/>

      <CheckBox Content="Ховати основне вікно під час запуску" Margin="0,14"
                IsChecked="{Binding HideMainWindowOnStartup}"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
         <ui:Button Content="Зберегти"  Width="90" Appearance="Primary" IsDefault="True" Click="OnSave" Margin="0,0,8,0"/>
         <ui:Button Content="Скасувати" Width="90" IsCancel="True"/>
      </StackPanel>

   </StackPanel>
</Window>
