<UserControl x:Class="NetSdrMonitor.Desktop.Features.Console.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:NetSdrMonitor.Desktop.Converters">
    <UserControl.Resources>
        <conv:LogLevelToBrushConverter x:Key="LevelBrush" />
    </UserControl.Resources>

    <Grid Background="#FBFBFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- шапка консолі -->
        <Border Grid.Row="0" Background="#EEEFF3" BorderBrush="#DADCE2" BorderThickness="0,1,0,1" Padding="8,4">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Консоль монітора" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Content="Очистити" Command="{Binding ClearCommand}" Padding="10,2" />
            </DockPanel>
        </Border>

        <!-- стрічка логів -->
        <ListBox Grid.Row="1" x:Name="LogList" ItemsSource="{Binding Entries}"
                 BorderThickness="0" Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.ScrollChanged="OnLogScroll"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="2,0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Line}" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="{Binding Level, Converter={StaticResource LevelBrush}}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
