<UserControl x:Class="NetSdrMonitor.Desktop.Features.Tray.AppTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:behaviors="clr-namespace:NetSdrMonitor.Desktop.Behaviors">
    <UserControl.Resources>
        <!-- проксі тримає DataContext (=AppTray) для меню поза візуальним деревом -->
        <behaviors:BindingProxy x:Key="Self" Data="{Binding}" />
    </UserControl.Resources>

    <tb:TaskbarIcon x:Name="TrayIcon"
                    IconSource="/Assets/Icons/app.ico"
                    ToolTipText="NetSdrMonitor"
                    LeftClickCommand="{Binding ShowMainCommand}">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <ContextMenu.ItemsSource>
                    <CompositeCollection>
                        <CollectionContainer Collection="{Binding Data.StatusLines, Source={StaticResource Self}}" />
                        <Separator />
                        <MenuItem Header="Основне вікно" Command="{Binding Data.ShowMainCommand,     Source={StaticResource Self}}" />
                        <MenuItem Header="Налаштування" Command="{Binding Data.OpenSettingsCommand, Source={StaticResource Self}}" />
                        <Separator />
                        <MenuItem Header="Вийти" Command="{Binding Data.ExitCommand,         Source={StaticResource Self}}" />
                    </CompositeCollection>
                </ContextMenu.ItemsSource>

                <ContextMenu.ItemContainerStyle>
                    <!-- лише для динамічних рядків статусу: показуємо Header, робимо некликабельними -->
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Header}" />
                        <Setter Property="IsEnabled" Value="False" />
                    </Style>
                </ContextMenu.ItemContainerStyle>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>
</UserControl>