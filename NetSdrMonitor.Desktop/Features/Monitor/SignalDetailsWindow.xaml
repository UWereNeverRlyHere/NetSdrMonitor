<ui:FluentWindow x:Class="NetSdrMonitor.Desktop.Features.Monitor.SignalDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:windowing="clr-namespace:NetSdrMonitor.Desktop.Features.Windowing"
        xmlns:controls="clr-namespace:NetSdrMonitor.Desktop.Controls"
        Title="Сигнали запису" MinHeight="400" MinWidth="500"
        windowing:WindowFraction.WidthFraction="0.35"
        windowing:WindowFraction.HeightFraction="0.3"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="14"
        Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterOwner">

    <DockPanel>

        <!-- власна плашка заголовка: єдиний стиль шапки з головним вікном -->
        <ui:TitleBar DockPanel.Dock="Top" Title="Сигнали запису"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     MinHeight="25" Height="28" MaxHeight="35">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/Icons/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" MinHeight="90" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryText" Grid.Row="0" Margin="2,0,2,8" FontWeight="SemiBold" TextWrapping="Wrap" />

        <DataGrid x:Name="DetailsGrid" Grid.Row="1"
                  Style="{StaticResource AppDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Час" 
                                    MinWidth="100" Width="130" MaxWidth="200"
                                    Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="Частота, МГц" 
                                    MinWidth="100" Width="130" MaxWidth="200"
                                    Binding="{Binding FrequencyMhz, StringFormat='{}{0:F3}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="Смуга, кГц" 
                                    MinWidth="100" Width="110" MaxWidth="200"
                                    Binding="{Binding BandwidthKhz, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="SNR, дБ"
                                    MinWidth="100" Width="*" MaxWidth="200"
                                    Binding="{Binding SnrDb, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- роздільник: тягнемо межу таблиці й спектра по вертикалі -->
        <GridSplitter Grid.Row="2" Height="6" Margin="0,6"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Background="{DynamicResource CardStrokeColorDefaultBrush}" Cursor="SizeNS" />

        <!-- смужка спектра під таблицею: частота → SNR, на всю ширину.
             суцільне тло панелі дає Border, а сам графік — прозорий -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <DockPanel Margin="8,6,8,8">
                <TextBlock DockPanel.Dock="Top" Margin="2,0,2,4" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Спектр запису: частота (МГц) → SNR (дБ)" />
                <controls:SpectrumChart x:Name="Spectrum"
                                        BarBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                        AxisBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        LabelBrush="{DynamicResource TextFillColorSecondaryBrush}"
                                        MedianBrush="{DynamicResource SystemFillColorCautionBrush}" />
            </DockPanel>
        </Border>
    </Grid>
    </DockPanel>
</ui:FluentWindow>
