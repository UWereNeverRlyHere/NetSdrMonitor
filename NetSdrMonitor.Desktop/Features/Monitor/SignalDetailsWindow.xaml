<ui:FluentWindow x:Class="NetSdrMonitor.Desktop.Features.Monitor.SignalDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:behaviors="clr-namespace:NetSdrMonitor.Desktop.Behaviors"
        Title="Сигнали запису" MinHeight="400" MinWidth="500"
        behaviors:WindowFraction.WidthFraction="0.35"
        behaviors:WindowFraction.HeightFraction="0.3"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="14"
        Icon="/Assets/Icons/app.ico" WindowStartupLocation="CenterOwner">

    <DockPanel>

        <!-- власна плашка заголовка: єдиний стиль шапки з головним вікном -->
        <ui:TitleBar DockPanel.Dock="Top" Title="Сигнали запису"
                     Background="{DynamicResource ApplicationBackgroundBrush}"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     MinHeight="25" Height="28" MaxHeight="35">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Assets/Icons/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SummaryText" Grid.Row="0" Margin="2,0,2,8" FontWeight="SemiBold" TextWrapping="Wrap" />

        <DataGrid x:Name="DetailsGrid" Grid.Row="1"
                  Style="{StaticResource AppDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  BorderThickness="1" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Час" Width="130"
                                    Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="Частота, МГц" Width="130"
                                    Binding="{Binding FrequencyMhz, StringFormat='{}{0:F3}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="Смуга, кГц" Width="110"
                                    Binding="{Binding BandwidthKhz, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
                <DataGridTextColumn Header="SNR, дБ" Width="*"
                                    Binding="{Binding SnrDb, StringFormat='{}{0:F1}'}"
                                    ElementStyle="{StaticResource CellCenter}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </DockPanel>
</ui:FluentWindow>
