<Application x:Class="NetSdrMonitor.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:NetSdrMonitor.Desktop"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- базова тема Fluent (Light як стартова); фактичний режим виставляє ThemeApplier на старті -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <!-- стиль кнопок: успадковує рідний вигляд WPF-UI, додає лише курсор-палець і темний фон при наведенні -->
            <Style x:Key="AppButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Cursor" Value="Hand" />
                <Style.Resources>
                    <!-- рідний шаблон бере фон наведення саме з цього ключа — підміняємо лише його -->
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#B8B0B0" />
                </Style.Resources>
                <Style.Triggers>
                    <!-- на темному фоні робимо текст/іконку білими для контрасту -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="White" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <Style x:Key="AppRepeatButton" TargetType="RepeatButton" BasedOn="{StaticResource {x:Type RepeatButton}}">
                <Setter Property="Cursor" Value="Hand" />
                <Style.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#4A4A4A" />
                </Style.Resources>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="White" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- спільний стиль таблиць: «шашка» рядків (парні/непарні — трохи різний фон).
                 рідний шаблон WPF-UI бере фон рядка з RowBackground/AlternatingRowBackground за AlternationIndex -->
            <Style x:Key="AppDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                <Style.Resources>
                    <!-- фон виділеного (і наведеного) рядка: рідний шаблон бере його саме з цього ключа.
                         робимо напівпрозорий синій — явно відрізняється від сірої «шашки», читабельний на обох темах -->
                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#552D7FF6" />
                </Style.Resources>
                <Setter Property="AlternationCount" Value="2" />
                <Setter Property="RowBackground" Value="Transparent" />
                <!-- напівпрозорий сірий: видно «шашку» і на світлій, і на темній темі (тема-незалежний) -->
                <Setter Property="AlternatingRowBackground" Value="#22808080" />
                <!-- заголовки по центру: успадковуємо САМЕ стиль заголовка WPF-UI (а не системний),
                     інакше злітає тема; його шаблон центрує контент за HorizontalContentAlignment -->
                <Setter Property="ColumnHeaderStyle">
                    <Setter.Value>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DefaultUiDataGridColumnHeaderStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- вирівнювання вмісту клітинок по центру (спільне для обох таблиць) -->
            <Style x:Key="CellCenter" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>