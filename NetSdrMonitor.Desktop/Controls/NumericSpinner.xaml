<UserControl x:Class="NetSdrMonitor.Desktop.Controls.NumericSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
   <UserControl.Resources>
      <!-- стрілки тримаємо компактними й незалежними від навколишньої теми: власний неявний -->
      <!-- стиль перекриває будь-який зовнішній для RepeatButton усередині спінера -->
      <Style TargetType="RepeatButton">
         <Setter Property="MinWidth" Value="0"/>
         <Setter Property="MinHeight" Value="0"/>
         <Setter Property="Padding" Value="0"/>
         <Setter Property="FontSize" Value="7"/>
      </Style>
   </UserControl.Resources>
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="*"/>
         <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <!-- введення з клавіатури оновлює значення одразу (живий фільтр); валідність символів — у code-behind -->
      <TextBox x:Name="Input" Grid.Column="0" VerticalContentAlignment="Center"
               PreviewTextInput="OnPreviewTextInput" DataObject.Pasting="OnPaste"
               Text="{Binding Value, ElementName=Root, StringFormat={}{0:0.####}, UpdateSourceTrigger=PropertyChanged}"/>

      <StackPanel Grid.Column="1" Width="20" Margin="2,0,0,0" VerticalAlignment="Center">
         <RepeatButton Content="▲" Click="OnUp"/>
         <RepeatButton Content="▼" Click="OnDown"/>
      </StackPanel>
   </Grid>
</UserControl>
