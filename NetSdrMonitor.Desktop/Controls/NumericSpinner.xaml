<UserControl x:Class="NetSdrMonitor.Desktop.Controls.NumericSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="18"/>   <!-- ширина колонки стрілок -->
        </Grid.ColumnDefinitions>

        <TextBox x:Name="Input" Grid.Column="0" VerticalContentAlignment="Center"
                 PreviewTextInput="OnPreviewTextInput" DataObject.Pasting="OnPaste"
                 PreviewKeyDown="OnInputKeyDown"

                 Text="{Binding Value, ElementName=Root, StringFormat={}{0:0.####}, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- стрілки одна над одною: кожна займає половину висоти контролу -->
        <Grid Grid.Column="1" Margin="2,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <RepeatButton Grid.Row="0" Content="▲" Click="OnUp"
                          Style="{StaticResource AppRepeatButton}"
                          FontSize="9" Padding="0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"/>
            <RepeatButton Grid.Row="1" Content="▼" Click="OnDown"
                          Style="{StaticResource AppRepeatButton}"
                          FontSize="9" Padding="0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"/>
        </Grid>
    </Grid>
</UserControl>
